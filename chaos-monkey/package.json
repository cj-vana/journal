{
  "name": "chaos-monkey",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "npx playwright test",
    "test:chaos": "npx playwright test --project=chaos",
    "test:e2e": "npx playwright test --project=e2e",
    "test:a11y": "npx playwright test --project=accessibility",
    "test:responsive": "npx playwright test --project=responsive",
    "test:perf": "npx playwright test --project=performance",
    "start": "ts-node src/monkey.ts",
    "dev": "ts-node src/monkey.ts",
    "ui-chaos": "ts-node src/ui-chaos-runner.ts",
    "report": "npx playwright show-report"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dockerode": "^4.0.0",
    "express": "^4.21.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/dockerode": "^3.3.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
