generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          String    @default("member")
  avatarColor   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entries       Entry[]
  milestones    Milestone[]
  growthRecords GrowthRecord[]
  mediaUploads  Media[]
  invitesCreated InviteCode[] @relation("CreatedInvites")
}

model Entry {
  id          String    @id @default(cuid())
  title       String?
  content     String
  contentHtml String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  entryDate   DateTime
  isDraft     Boolean   @default(false)

  tags        EntryTag[]
  media       Media[]

  @@index([authorId])
  @@index([entryDate])
  @@index([createdAt])
  @@index([isDraft, entryDate])
  @@index([isDraft, authorId, entryDate])
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  color     String?
  icon      String?
  createdAt DateTime   @default(now())
  entries   EntryTag[]
}

model EntryTag {
  entryId String
  tagId   String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([entryId, tagId])
}

model Media {
  id         String   @id @default(cuid())
  entryId    String?
  entry      Entry?   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  uploadedBy String?
  uploader   User?    @relation(fields: [uploadedBy], references: [id])
  type       String
  filename   String
  path       String
  mimeType   String
  size       Int
  caption    String?
  createdAt  DateTime @default(now())
  @@index([entryId])
  @@index([type])
  @@index([uploadedBy])
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  category    String?
  icon        String?
  photoPath   String?
  recordedBy  String
  recorder    User      @relation(fields: [recordedBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([date])
  @@index([category])
  @@index([recordedBy])
}

model GrowthRecord {
  id          String    @id @default(cuid())
  date        DateTime
  heightCm    Float?
  weightKg    Float?
  headCm      Float?
  notes       String?
  recordedBy  String
  recorder    User      @relation(fields: [recordedBy], references: [id])
  createdAt   DateTime  @default(now())
  @@index([date])
  @@index([recordedBy])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdById String
  createdBy   User      @relation("CreatedInvites", fields: [createdById], references: [id])
  usedAt      DateTime?
  usedByEmail String?
  expiresAt   DateTime?
  maxUses     Int       @default(1)
  useCount    Int       @default(0)
  createdAt   DateTime  @default(now())
}

model WritingPrompt {
  id       String  @id @default(cuid())
  text     String
  category String?
  isActive Boolean @default(true)
  @@index([isActive])
}

model AppSettings {
  id             String    @id @default("singleton")
  childName      String    @default("Baby")
  appTitle       String    @default("Our Journal")
  childBirthDate DateTime?
  theme          String    @default("warm")
  gender         String    @default("neutral")
  updatedAt      DateTime  @updatedAt
}
