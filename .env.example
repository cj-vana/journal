# Auth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Initial admin account (used only during first seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Database
DATABASE_URL=file:./data/db/journal.db

# Uploads
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20

# Debug (set to true ONLY for testing, never in production)
ENABLE_DEBUG_PROFILE=false
DEBUG_KEY=generate-a-random-key-here
